# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — Copy this to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:password@localhost:27017
MONGODB_DATABASE=environmental_db

# ── API Keys (optional) ───────────────
# OpenAQ API key: https://api.openaq.org/
# OPENAQ_API_KEY=

# OpenWeather API key: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Risk Alert — Email (Gmail App Password) ───────────────────────────────────
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=
ALERT_RISK_THRESHOLD=50
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587