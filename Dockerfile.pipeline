# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.pipeline
# Lightweight image for the Bronze Kafka consumer (long-running service)
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Project code is mounted via volume at runtime
ENV PYTHONPATH=/app
